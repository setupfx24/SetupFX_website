# =============================================================
# FXArtha — Single .env (repo root) — ONE file for everything
# =============================================================
# Copy to .env and fill in real values. Never commit .env to git.
#
# This file is the ONLY .env needed:
#   • Docker Compose reads it for ${VAR} substitution in docker-compose.yml
#   • All backend services load it via env_file
#   • Frontend containers use only the vars set in docker-compose.yml environment:
#
# DO NOT create backend/.env — it is no longer used.
# =============================================================

# ─── PostgreSQL ───────────────────────────────────────────────
POSTGRES_USER=fxartha
POSTGRES_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
POSTGRES_DB=fxartha

# ─── TimescaleDB ──────────────────────────────────────────────
TIMESCALE_USER=fxartha
TIMESCALE_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
TIMESCALE_DB=marketdata

# ─── Connection URLs (must match passwords above) ─────────────
DATABASE_URL=postgresql+asyncpg://fxartha:CHANGE_THIS_STRONG_PASSWORD@postgres:5432/fxartha
TIMESCALE_URL=postgresql+asyncpg://fxartha:CHANGE_THIS_STRONG_PASSWORD@timescaledb:5432/marketdata
REDIS_URL=redis://redis:6379/0
# KAFKA_BOOTSTRAP_SERVERS removed — Kafka was deleted from the stack
# (see packages/common/src/kafka_client.py).

# ─── JWT Secrets — generate with: openssl rand -hex 32 ────────
JWT_SECRET=CHANGE_THIS_RANDOM_64_CHAR_STRING
USER_JWT_SECRET=CHANGE_THIS_RANDOM_64_CHAR_STRING
ADMIN_JWT_SECRET=CHANGE_THIS_OTHER_RANDOM_64_CHAR_STRING
# Access JWT lifetime (minutes). Refresh cookie is separate (JWT_REFRESH_EXPIRY_DAYS).
# Legacy env name JWT_EXPIRY_MINUTES is still accepted as an alias.
JWT_ACCESS_EXPIRY_MINUTES=45
JWT_REFRESH_EXPIRY_DAYS=7
# true = access + refresh cookies are browser-session only (close browser → log in again).
# false = persistent cookies (access ~JWT_ACCESS_EXPIRY_MINUTES, refresh JWT_REFRESH_EXPIRY_DAYS).
JWT_REFRESH_SESSION_COOKIE=true
# HttpOnly cookie flags (trader web). Leave COOKIE_SECURE unset to auto-detect HTTPS.
COOKIE_SAMESITE=strict
# COOKIE_SECURE=true
# Cookie Domain — set to a parent domain so the same session works on apex + trade subdomain.
# Production:
COOKIE_DOMAIN=.fxartha.com
# Local dev: leave blank or comment out (host-only cookies on localhost are correct).
# Set false only for local HTTP if browsers reject Secure cookies.
# JWT_INCLUDE_LEGACY_JSON_TOKEN=false

# ─── Environment & CORS ───────────────────────────────────────
ENVIRONMENT=production
# Trader (apex + user-app subdomain) + admin origins
CORS_ORIGINS=https://fxartha.com,https://trade.fxartha.com,https://admin.fxartha.com
# Trader site origin for password-reset email links (no trailing slash) — points at the user-app subdomain
TRADER_APP_URL=https://trade.fxartha.com

# Build-time host pair for trader-frontend (enables the marketing/app domain split).
# Marketing pages stay on NEXT_PUBLIC_MARKETING_HOST; everything else (auth, dashboard,
# wallet, portfolio, trading terminal, etc.) is served from NEXT_PUBLIC_TRADE_HOST.
# Leave blank for local dev so src/middleware.ts no-ops and a single host serves all routes.
NEXT_PUBLIC_MARKETING_HOST=fxartha.com
NEXT_PUBLIC_TRADE_HOST=trade.fxartha.com

# ─── Outbound email (password reset) ───────────────────────────
# If SMTP_HOST is empty, reset emails are NOT sent (production logs a warning; dev logs the link).
# Gmail: enable 2FA, create an App Password, use smtp.gmail.com:587, your full address as SMTP_USER.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASSWORD=your-16-char-app-password
# SMTP_FROM=FXArtha <you@gmail.com>
# SMTP_USE_TLS=true

# ─── Admin service ────────────────────────────────────────────
ADMIN_REDIS_URL=redis://redis:6379/1

# ─── Risk engine ──────────────────────────────────────────────
MARGIN_CALL_LEVEL=80.0
STOP_OUT_LEVEL=50.0
MAX_OPEN_TRADES=200
DEFAULT_LEVERAGE=100

# KYC file storage (gateway). Use an absolute path on a writable volume in production, e.g. /app/data/kyc
# KYC_UPLOAD_ROOT=/app/data/kyc
# Manual deposit screenshots + user payout QR images — mount the same path on gateway AND admin services.
# WALLET_UPLOAD_ROOT=/app/data/wallet

# ─── CORS (locked down for production) ─────────────────
CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Authorization,Content-Type,X-Requested-With,Accept

# ─── Sentry (error monitoring) ────────────────────────
# Leave empty to disable. Get a DSN from https://sentry.io
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
SENTRY_TRACES_SAMPLE_RATE=0.1

# ─── Rate Limiting ────────────────────────────────────
RATE_LIMIT_DEFAULT=60/minute
RATE_LIMIT_AUTH=10/minute
RATE_LIMIT_TRADING=120/minute

# ─── Request Size Limit (bytes, default 10 MB) ────────
MAX_REQUEST_SIZE=10485760

# ─── Google OAuth (Sign in / Sign up with Google) ─────
# Get a Web-application Client ID from https://console.cloud.google.com/apis/credentials
# Authorized JavaScript origins must include https://fxartha.com, https://trade.fxartha.com,
# and (for local dev) http://localhost:3010. No redirect URI is needed — we use the implicit
# id_token flow. The same value is exposed to the browser as NEXT_PUBLIC_GOOGLE_CLIENT_ID.
# Leave empty to disable Google sign-in (button is hidden, /auth/google returns 503).
GOOGLE_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# ─── NOWPayments crypto deposits ──────────────────────
# Hosted-invoice flow: user picks a crypto asset on the wallet page, we create
# an invoice via /v1/invoice with pay_currency pre-locked, and redirect them
# to NOWPayments' invoice_url. They pay; NOWPayments POSTs an IPN to
# https://${NOWPAYMENTS_CALLBACK_BASE_URL}/api/v1/webhooks/nowpayments
# signed with HMAC-SHA512 over the sorted-key JSON body using IPN_SECRET.
#
# Where to get these:
#   API key:    https://account.nowpayments.io/store-settings/api-keys
#   IPN secret: https://account.nowpayments.io/store-settings/ipn-settings
#
# Set NOWPAYMENTS_SANDBOX=true to point at api-sandbox.nowpayments.io for
# testnet smoke tests. Leave empty (or unset NOWPAYMENTS_API_KEY) and the
# /wallet/deposit endpoint returns "NOWPayments not configured".
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
NOWPAYMENTS_SANDBOX=false
NOWPAYMENTS_CALLBACK_BASE_URL=https://api.fxartha.com

# ─── Decentralized USDT deposits (TRC20 / BEP20 / ERC20) ──────────────
# The chain_verifier_engine watches user-submitted tx hashes for the new
# wallet-connect deposit flow and credits the user when the on-chain
# transfer to the admin deposit address is confirmed.
#
# All four are optional. With no keys configured, public/free endpoints
# are used (rate-limited but workable at low volume). For production you
# should set Etherscan/BscScan API keys (free tier ok) and an Alchemy URL
# for ETH RPC, otherwise a chain hiccup may stall verification.
#
#   Etherscan API key:  https://etherscan.io/myapikey
#   BscScan API key:    https://bscscan.com/myapikey
#   TronGrid API key:   https://www.trongrid.io  (optional — public works)
#   Alchemy URL:        https://dashboard.alchemy.com  (paste full https URL incl key)
ETHERSCAN_API_KEY=
BSCSCAN_API_KEY=
TRONGRID_API_KEY=
ALCHEMY_API_URL=
BSC_RPC_URL=
TRON_API_URL=https://api.trongrid.io

# WalletConnect project id (Reown Cloud) — required by RainbowKit so the
# WalletConnect QR + mobile-deeplink flows work. Get one (free) at
# https://cloud.reown.com → Create Project → copy "Project ID". Without it,
# RainbowKit only surfaces injected wallets (MetaMask, OKX, Brave) and the
# WalletConnect-based ones (Trust Wallet mobile, etc.) won't connect.
# Baked into the trader-frontend bundle at Docker build time.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# ─── Market Data (Infoway.io) ─────────────────────────
# Used by Docker service `market-data` (publishes ticks to Redis). Gateway/trader read Redis.
# Leave empty or use a real key from Infoway dashboard; placeholders → simulated feed only.
INFOWAY_API_KEY=your-infoway-api-key-here
INFOWAY_API_URL=https://api.infoway.io

# ─── Default admin UI login (init-db.sql + alembic revision 0002) ───
# Set these before running migrations to seed the super_admin with your desired credentials.
# Change password after first login; run: docker compose --profile migrate run --rm migrate
ADMIN_EMAIL=admin@fxartha.com
ADMIN_PASSWORD=FXArthaAdmin2025!


# ─── Backup & Disaster Recovery ───────────────────────
# Daily Postgres + TimescaleDB + uploads/ snapshots. See scripts/backup.sh
# and docs/disaster-recovery.md for the full pipeline + restore runbook.
#
# Local backup directory on the host. The script creates it automatically.
BACKUP_LOCAL_DIR=/opt/fxartha/backups
# Days of local + remote backups to retain. Older archives are deleted by
# the daily cron sweep.
BACKUP_RETENTION_DAYS=14
# Optional rclone remote name + path. Empty = local-only (NOT safe for
# prod — losing the disk loses the backup too). Configure once with
# `rclone config` then put the remote name here, e.g. "b2:fxartha-backups".
# Recommended provider: Backblaze B2 ($0.005/GB/mo, free egress for 3×).
BACKUP_RCLONE_REMOTE=
# GPG passphrase for symmetric AES-256 encryption of every dump. MUST be
# set in production — backups contain KYC documents, password hashes,
# and PII. Generate with `openssl rand -hex 32` and store in a password
# manager (1Password / Bitwarden). DO NOT keep the passphrase in the
# same place as the backup files. Empty = unencrypted (loud warning,
# unsafe in prod).
BACKUP_GPG_PASSPHRASE=


