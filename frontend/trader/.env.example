# =============================================================
# SwissCresta Trader Frontend — Environment Variables
# Copy to .env.local for development; set via Docker/host env in prod.
# =============================================================

# ─── SERVER-ONLY (NOT exposed to browser) ────────────────────────

# Internal gateway URL for Next.js API proxy.
# Priority order (proxy resolves first non-empty):
#   TRADER_API_PROXY_TARGET > GATEWAY_URL > INTERNAL_API_URL > NEXT_PUBLIC_GATEWAY_ORIGIN > localhost
# Docker compose default: http://gateway:8000
# Local dev fallback: http://127.0.0.1:8000
# TRADER_API_PROXY_TARGET=http://gateway:8000
# GATEWAY_URL=http://gateway:8000
# INTERNAL_API_URL=http://gateway:8000/api/v1
# GATEWAY_INTERNAL_URL=http://gateway:8000

# Docker build flag — required for `next build` to emit .next/standalone/
# which the Dockerfile copies into the runner stage. Set automatically
# in the Dockerfile, no need to set locally.
# NEXT_OUTPUT_STANDALONE=true

# ─── NEXT_PUBLIC_* — BAKED INTO JS BUNDLE AT BUILD TIME ──────────
# IMPORTANT: on HTTPS sites, NEVER set these to http:// or ws:// —
# browsers block mixed content. Leave UNSET in production for the
# app to auto-detect protocol from the current origin.

# Build cache buster. Set to commit SHA or timestamp at Docker build
# (`--build-arg NEXT_PUBLIC_APP_VERSION=$(git rev-parse HEAD)`) so each
# deploy gets new `_next/static/` URLs. Default 'docker' in Dockerfile.
# NEXT_PUBLIC_APP_VERSION=

# Production host split. Both required for middleware host-based routing.
# If EITHER is unset, middleware silently no-ops (host split disabled).
# NEXT_PUBLIC_MARKETING_HOST=swisscresta.com
# NEXT_PUBLIC_TRADE_HOST=trade.swisscresta.com

# Google OAuth client ID for the "Sign in with Google" button.
# Get from Google Cloud Console > APIs & Services > Credentials.
# This is a PUBLIC identifier per Google's OAuth model — safe in browser.
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# WebSocket price-feed URL override. Only needed for local dev (HTTP).
# Production auto-detects: wss://<current host>/ws/prices (Nginx must
# proxy /ws/ to gateway).
# NEXT_PUBLIC_WS_URL=ws://localhost:8000

# Direct browser-to-gateway URL. Set ONLY if you don't want browser
# calls to go through the Next.js /api/v1 proxy. Most deploys leave
# these UNSET so calls stay same-origin.
# NEXT_PUBLIC_GATEWAY_URL=
# NEXT_PUBLIC_GATEWAY_ORIGIN=
# NEXT_PUBLIC_API_URL=
